// Prisma schema for CV Tailor
// Database: Railway PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// App user, linked 1:1 to a Clerk account.
model User {
  id          String    @id @default(cuid())
  clerkId     String    @unique
  email       String    @unique
  plan        String    @default("free") // "free" | "pro"
  onboardedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  resumes      Resume[]
  adaptations  Adaptation[]
  applications Application[]
}

/// A master resume uploaded by the user. `data` holds the parsed,
/// structured representation (the data-слой) produced from the source file.
model Resume {
  id           String   @id @default(cuid())
  userId       String
  title        String   @default("Моё резюме")
  originalText String?  @db.Text
  data         Json?
  originalData Json? // snapshot of the first machine parse, for "revert to source"
  photo        String? @db.Text // optional photo as data URL, used in 2-column PDF templates
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adaptations Adaptation[]

  @@index([userId])
}

/// A tailoring of a master resume to a specific job posting.
/// `jobData` is the parsed JD; `adaptedData`/`matchScore`/`gaps` are filled by
/// later steps (AI adaptation, score, gap analysis).
model Adaptation {
  id          String   @id @default(cuid())
  userId      String
  resumeId    String
  title       String   @default("Адаптация")
  jobText     String?  @db.Text
  jobData     Json?
  adaptedData Json?
  matchScore  Int?
  gaps        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume       Resume              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  versions     AdaptationVersion[]
  applications Application[]

  @@index([userId])
  @@index([resumeId])
}

/// A job application tracked on the kanban board.
model Application {
  id           String   @id @default(cuid())
  userId       String
  company      String   @default("")
  role         String   @default("")
  link         String?
  stage        String   @default("wishlist") // wishlist|applied|interview|offer|rejected
  notes        String?  @db.Text
  contactName  String?
  contactInfo  String?
  adaptationId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  adaptation Adaptation? @relation(fields: [adaptationId], references: [id], onDelete: SetNull)

  @@index([userId])
}

/// A saved snapshot of an adapted resume — one per AI adaptation run, so the
/// user can review history and restore an earlier version.
model AdaptationVersion {
  id           String   @id @default(cuid())
  adaptationId String
  data         Json
  matchScore   Int?
  createdAt    DateTime @default(now())

  adaptation Adaptation @relation(fields: [adaptationId], references: [id], onDelete: Cascade)

  @@index([adaptationId])
}
